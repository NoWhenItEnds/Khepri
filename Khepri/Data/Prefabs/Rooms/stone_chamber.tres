[ext_resource type="Script" uid="uid://dqias8m1ucccw" path="res://Khepri/Systems/Rooms/Features/Feature.cs" id="1_feature"]
[ext_resource type="Script" uid="uid://dvo54q23dri4x" path="res://Khepri/Systems/Rooms/RoomPrefab.cs" id="2_roomprefab"]
[ext_resource type="Script" uid="uid://bq7atmosf3x2k" path="res://Khepri/Systems/Rooms/Features/AtmosphereFeature.cs" id="3_atmosphere"]
[ext_resource type="Script" uid="uid://c2carvngs8m4p" path="res://Khepri/Systems/Rooms/Features/CarvingsFeature.cs" id="4_carvings"]
